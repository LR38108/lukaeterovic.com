# Copy to .env.local and fill in. Restart `npm run dev` after changes.

# Must match Worker secret: npx wrangler secret put ADMIN_TOKEN
# Used for API calls (upload, save, delete). Never committed.
VITE_ADMIN_TOKEN=

# Optional: short password only for opening /admin in the browser.
# If unset, you log in with VITE_ADMIN_TOKEN instead.
# VITE_ADMIN_PASS=

# Optional (defaults to production Worker URL if unset)
# VITE_API_BASE_URL=https://lukaeterovic-api.radan-luka.workers.dev

# Contact page — WhatsApp “Chat on Whatsapp” link (digits only, with country code, e.g. 385911234567)
# VITE_CONTACT_WHATSAPP=
